<suite name="Suite" parallel="tests" thread-count="2">

    <test name="Example_Test">
        <classes>
            <class name="sampletests.LoginTest"/>
        </classes>
    </test>
    <test name="Browser_Test">
        <classes>
            <class name="sampletests.BrowserTest"/>
        </classes>
    </test>

    <test name="Chrome">

        <parameter name="browser" value="chrome"/>

        <classes>
            <class name="sampletests.BrowserTestParameter"/>
        </classes>

    </test>
    <test name="Firefox">

        <parameter name="browser" value="firefox"/>

        <classes>
            <class name="sampletests.BrowserTestParameter"/>
        </classes>

    </test>
</suite>